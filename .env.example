# 数据库配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=campus_guard
POSTGRES_PASSWORD=campus_guard_secret
POSTGRES_DB=campus_guard
DATABASE_URL=postgresql://campus_guard:campus_guard_secret@localhost:5432/campus_guard

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# API 配置
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# 前端配置
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# 流媒体核心配置
STREAM_CORE_HOST=localhost
STREAM_CORE_PORT=9000
MAX_STREAMS=20

# AI Runtime 配置
AI_RUNTIME_HOST=localhost
AI_RUNTIME_PORT=9001
ONNX_MODEL_PATH=./models

# 日志级别
LOG_LEVEL=INFO
